#!/usr/bin/env bash
# project-resolve — Resolver alias natural a slug canonical
# Uso: project-resolve "mi proyecto"

set -euo pipefail

WORKSPACE="${MOTHERSHIP_WORKSPACE:-}"
if [ -z "$WORKSPACE" ]; then
    for candidate in "$HOME/.openclaw/workspace" "$HOME/mothership-workspace"; do
        [ -d "$candidate" ] && WORKSPACE="$candidate" && break
    done
fi

if [ $# -lt 1 ]; then
    echo "Uso: project-resolve <alias>"
    exit 1
fi

INPUT="$*"
INPUT_LOWER="$(echo "$INPUT" | tr '[:upper:]' '[:lower:]')"

# 1. Match directo por slug
if [ -d "$WORKSPACE/projects/$INPUT_LOWER" ]; then
    echo "$INPUT_LOWER"
    exit 0
fi

# 2. Buscar en META.json aliases de cada proyecto
if command -v python3 &> /dev/null; then
    MATCH=$(python3 - <<EOF
import json, os, glob, sys
ws = "$WORKSPACE"
inp = "$INPUT_LOWER".strip()
inp_normalized = inp.replace(" ", "-")
for meta_path in glob.glob(f"{ws}/projects/*/META.json"):
    try:
        with open(meta_path) as f:
            meta = json.load(f)
        slug = meta.get("slug", "")
        aliases = [a.lower() for a in meta.get("aliases", [])]
        if inp == slug or inp in aliases or inp_normalized == slug or inp_normalized in aliases:
            print(slug)
            sys.exit(0)
    except Exception:
        continue
sys.exit(1)
EOF
)
    if [ -n "$MATCH" ]; then
        echo "$MATCH"
        exit 0
    fi
fi

# 3. Buscar en PROJECT_REGISTRY.md
if [ -f "$WORKSPACE/PROJECT_REGISTRY.md" ]; then
    # Buscar por aliases (formato: - Aliases: `alias1`, `alias2`)
    FOUND=$(grep -B 10 -i "$INPUT" "$WORKSPACE/PROJECT_REGISTRY.md" | grep -oE "^### [a-z0-9-]+" | tail -1 | sed 's/### //')
    if [ -n "$FOUND" ]; then
        echo "$FOUND"
        exit 0
    fi
fi

echo "ERROR: no se resolvió '$INPUT' a ningún proyecto." >&2
echo "Proyectos disponibles:" >&2
ls -1 "$WORKSPACE/projects/" 2>/dev/null | sed 's/^/  - /' >&2
exit 1
